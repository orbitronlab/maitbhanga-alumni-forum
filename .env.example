# ─────────────────────────────────────────────
# DATABASE — Neon Free PostgreSQL
# Get from: https://neon.tech → Create Project → Copy connection string
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/alumni_forum?sslmode=require"

# ─────────────────────────────────────────────
# NEXTAUTH — REQUIRED
# NEXTAUTH_URL = your Vercel domain (e.g. https://alumni.vercel.app)
# NEXTAUTH_SECRET = run: openssl rand -base64 32
# ─────────────────────────────────────────────
NEXTAUTH_URL="https://your-project.vercel.app"
NEXTAUTH_SECRET="generate-a-32-char-random-string-here"

# ─────────────────────────────────────────────
# GOOGLE OAUTH (Optional)
# Get from: https://console.cloud.google.com → APIs → Credentials
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────
# EMAIL — Gmail SMTP
# Use Gmail App Password (not your regular password)
# Enable 2FA first, then: https://myaccount.google.com/apppasswords
# ─────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM="Maitbhanga Alumni Forum <your-gmail@gmail.com>"

# ─────────────────────────────────────────────
# APP URL — your Vercel domain
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# ─────────────────────────────────────────────
# CLOUDINARY — Free image uploads (optional)
# Get from: https://cloudinary.com (free 25GB)
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ─────────────────────────────────────────────
# PAYMENT GATEWAYS (optional - for future use)
# ─────────────────────────────────────────────
BKASH_BASE_URL="https://tokenized.sandbox.bka.sh/v1.2.0-beta"
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""
BKASH_CALLBACK_URL="https://your-project.vercel.app/api/payments/bkash/callback"

NAGAD_BASE_URL="http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0"
NAGAD_MERCHANT_ID=""
NAGAD_MERCHANT_PRIVATE_KEY=""
NAGAD_PUBLIC_KEY=""

SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWD=""
SSLCOMMERZ_IS_LIVE="false"
SSLCOMMERZ_SUCCESS_URL="https://your-project.vercel.app/api/payments/sslcommerz/success"
SSLCOMMERZ_FAIL_URL="https://your-project.vercel.app/api/payments/sslcommerz/fail"
SSLCOMMERZ_CANCEL_URL="https://your-project.vercel.app/api/payments/sslcommerz/cancel"
SSLCOMMERZ_IPN_URL="https://your-project.vercel.app/api/payments/sslcommerz/ipn"
